{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bento",
  "description": "Production infrastructure for AI agents. Monitor what runs. Improve what fails. Compound learnings.",
  "colors": {
    "primary": "#FF3C00",
    "light": "#FF7A4D",
    "dark": "#C23D0F"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "heading": {
      "family": "Inter"
    },
    "body": {
      "family": "Inter"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Get started",
        "icon": "rocket",
        "groups": [
          {
            "group": "Overview",
            "icon": "house",
            "pages": ["index", "quickstart", "otel-export"]
          },
          {
            "group": "CLI",
            "icon": "terminal",
            "pages": ["cli/installation", "cli/commands"]
          },
          {
            "group": "Migrations",
            "icon": "right-left",
            "pages": ["migrations/langfuse", "migrations/raindrop"]
          },
          {
            "group": "Concepts",
            "icon": "book",
            "pages": [
              "concepts/data-model",
              "concepts/trajectories",
              "concepts/attributes",
              "concepts/sessions",
              "concepts/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "Python SDK",
        "icon": "python",
        "groups": [
          {
            "group": "Get started",
            "icon": "rocket",
            "pages": ["python/installation", "python/configuration"]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": ["python/integrations"]
          },
          {
            "group": "Manual tracking",
            "icon": "paper-plane",
            "pages": ["python/track-ai", "python/properties"]
          },
          {
            "group": "Advanced",
            "icon": "screwdriver-wrench",
            "pages": [
              "python/trajectories",
              "python/identity",
              "python/otel-transport",
              "python/threading-model"
            ]
          }
        ]
      },
      {
        "tab": "TypeScript SDK",
        "icon": "js",
        "tag": "Coming soon",
        "pages": ["typescript/index"]
      }
    ]
  },
  "redirects": [
    {
      "source": "/python/from-raindrop",
      "destination": "/migrations/raindrop",
      "permanent": true
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://bentolabs.ai"
  },
  "appearance": {
    "default": "dark"
  },
